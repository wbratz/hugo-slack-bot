# Copy to .env and fill in. The .env file is gitignored — never commit real values.

# --- Required ---
ANTHROPIC_API_KEY=sk-ant-...
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
HUGO_ADMIN_USER_ID=U01234567          # Slack user ID Hugo DMs on crashes

# --- Channels (names or IDs; IDs avoid a rate-limited lookup on startup) ---
HUGO_DIGEST_CHANNEL=#ai-summaries
HUGO_ANNOUNCE_CHANNEL=#general
# HUGO_WELCOME_CHANNEL=#general        # public greeting target; unset = DM only

# --- Behavior (optional; defaults shown) ---
# HUGO_WORKSPACE_NAME=the workspace    # used in intro / greeting copy
# HUGO_WELCOME_ENABLED=true            # false = digest + bot only, no greeter
# CLAUDE_MODEL=claude-sonnet-4-6
# HUGO_CURATOR_DAILY_CAP=3             # curator picks added to the queue per run
# HUGO_CURATOR_THRESHOLD=6             # min relevance score (1-10) to qualify
# HUGO_DIGEST_MAX_POSTS=3              # best-by-score curator picks posted per digest
# HUGO_TZ=UTC                          # set to your zone, e.g. America/Phoenix,
#                                      # so the Sat/Sun skip + date header are local
